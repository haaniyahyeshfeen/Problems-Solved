package mywork;

import java.util.*;

public class Factorial {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        System.out.print("Enter the Number: ");
        int n = sc.nextInt();

        int r = 1;

        for (int i = n; i >= 1; i--) {
            r *= i;
        }

        System.out.println("The Factorial value is = " + r);

        sc.close();
    }
}
